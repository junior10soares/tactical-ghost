# Groq (IA tática + transcrição) — gratuito, sem cartão: https://console.groq.com
GROQ_API_KEY=gsk_...

# Turso (banco de dados) — gratuito: https://turso.tech
TURSO_DATABASE_URL=libsql://tactical-ghost-xxxx.turso.io
TURSO_AUTH_TOKEN=ey...

NEXT_PUBLIC_APP_NAME=Tactical Ghost

# ElevenLabs (narração — plano Free): https://elevenlabs.io
# IMPORTANTE: o plano Free não permite usar vozes da Voice Library via API
# (erro 402 paid_plan_required), mesmo que a voz tenha sido salva na conta.
# Use uma voz "premade" (categoria padrão de toda conta nova, ex.: Bella,
# Roger, Sarah, Charlie, George, Callum, River). Para checar a categoria de
# uma voz: GET https://api.elevenlabs.io/v2/voices com sua API key.
ELEVENLABS_API_KEY=el-...
ELEVENLABS_NARRATOR_VOICE_ID=voice_id_premade

# LangSmith / LangGraph (observabilidade e orquestração) — free tier: https://smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=tactical-ghost
